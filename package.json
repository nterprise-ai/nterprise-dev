{
	"name": "@nterprise-ai/dev",
	"version": "0.1.1",
	"private": false,
	"type": "module",
	"main": "./dist/index.js",
	"bin": {
		"nterprise": "./src/cli.ts"
	},
	"exports": {
		".": "./dist/index.js",
		"./themes": {
			"import": "./dist/themes/index.js",
			"types": "./dist/themes/index.d.ts"
		},
		"./website-builder": "./dist/website-builder/index.js"
	},
	"scripts": {
		"prepack": "chmod +x src/cli.ts",
		"build": "tsc --build",
		"test": "bun test",
		"lint": "biome check .",
		"lint:fix": "biome check --write ."
	},
	"publishConfig": {
		"registry": "https://npm.pkg.github.com"
	},
	"repository": {
