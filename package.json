		"react": {
			"optional": true
		}
	},
	"dependencies": {
		"culori": "^4.0.2"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@types/bun": "^1.3.14",
		"@types/culori": "^4.0.1",
		"@types/react": "^19.2.15",
		"typescript": "^6.0.3"
	}
