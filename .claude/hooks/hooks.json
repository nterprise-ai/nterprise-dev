{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsx .claude/hooks/guardian.ts"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsx .claude/hooks/guardian.ts"
          },
          {
            "type": "command",
            "command": "npx tsx .claude/hooks/worktree-path-guard.ts"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx tsx .claude/hooks/context-inject.ts"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx tsx .claude/hooks/continue-or-stop.ts"
          },
          {
            "type": "command",
            "command": "npx tsx .claude/hooks/learner.ts",
            "async": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsx .claude/hooks/cost-watch.ts",
            "async": true
          }
        ]
      }
    ]
  }
}
